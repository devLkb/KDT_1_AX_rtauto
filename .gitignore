# Unity — 열 때 자동 생성되는 것들
unity/Library/
unity/Temp/
unity/Obj/
unity/Logs/
unity/UserSettings/
unity/MemoryCaptures/
unity/Screenshots/
unity/*.csproj
unity/*.sln

# Python
venv/
.venv/
vision/.vision/
__pycache__/
*.pyc
.ipynb_checkpoints/

# 로컬 환경변수·비밀값 (공유 가능한 예제 파일만 허용)
.env
.env.*
!.env.example

# 런타임 로그·산출물 (스크립트가 실행마다 생성)
vision/**/*.csv
vision/**/vision_dg5f_*.csv
vision/**/calib_log_*.csv
*.log
*.pid

# ML-Agents training/build outputs
training/results/
training/builds/
training/archives/*.tar.gz
training/logs/*.png
training/logs/*.gif
training/logs/recovered/
/DG5FStableGrasp-*.tar.xz
unity/Assets/MLAgents/Grasp/Models/*.onnx

# 로컬 배포 압축본·편집기 백업
/*.tar.gz
/*.tgz
/*.zip
*.backup
*.bak
*~

# 네이티브 crash dump
core
core.*

# OS
Thumbs.db
.DS_Store

