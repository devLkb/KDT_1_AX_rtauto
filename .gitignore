# Unity — 편집기/IDE가 자동 생성하는 로컬 산출물
unity/[Ll]ibrary/
unity/[Tt]emp/
unity/[Oo]bj/
unity/[Ll]ogs/
unity/[Uu]ser[Ss]ettings/
unity/[Bb]uild/
unity/[Bb]uilds/
unity/MemoryCaptures/
unity/Screenshots/
unity/Recordings/
unity/CrashReports/
unity/*.csproj
unity/*.sln
unity/*.slnx
unity/*.userprefs

# ML-Agents 프로파일러가 실행마다 생성하는 타이머
unity/Assets/ML-Agents/Timers/

# 소스 Assets의 *.meta는 Unity GUID/참조 정보이므로 의도적으로 무시하지 않는다.
# 위 ML-Agents 타이머처럼 폴더 전체가 생성물인 경우만 예외다.

# Python
venv/
.venv/
vision/.vision/
__pycache__/
*.pyc
.ipynb_checkpoints/

# 로컬 환경변수·비밀값 (공유 가능한 예제 파일만 허용)
.env
.env.*
!.env.example

# 런타임 로그·산출물 (스크립트가 실행마다 생성)
vision/**/*.csv
vision/**/vision_dg5f_*.csv
vision/**/calib_log_*.csv
*.log
*.pid

# ZED 3D 비전(YOLO 커스텀 학습) — 촬영 이미지/학습 산출물/사전학습 가중치는 제외
vision/zed_object_detection/dataset/
vision/zed_object_detection/runs/
vision/zed_object_detection/*.pt
# 파인튜닝된 커스텀 타겟 모델은 예외로 보존
!vision/zed_object_detection/weights/dg5f_target_objects_yolov8s.pt

# ML-Agents training/build outputs
training/results/
training/builds/
training/archives/*.tar.gz
training/logs/*.png
training/logs/*.gif
training/logs/recovered/
/DG5FStableGrasp-*.tar.xz
# 학습 중 생성되는 정책은 제외하되, 현재 Grasp 환경의 배포 모델은 소스와 함께 보존한다.
unity/Assets/MLAgents/Grasp/Models/*.onnx
!unity/Assets/MLAgents/Grasp/Models/DG5FGrasp.onnx

# 로컬 배포 압축본·편집기 백업
/*.tar.gz
/*.tgz
/*.zip
*.backup
*.bak
*~

# 네이티브 crash dump
core
core.*

# OS
Thumbs.db
.DS_Store

# Agents
*.omc
*.omx
*.claude
