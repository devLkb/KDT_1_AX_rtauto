# This file contains the shared defaults. Copy it to .env to override them locally:
#   cp .env.example .env
#
# Relative paths are resolved from the repository root.
# Priority: process environment > .env > .env.example.

# Grasp headless-compatible Linux player
DG5F_GRASP_BUILD_OUTPUT=training/builds/DG5FGrasp
DG5F_GRASP_PLAYER_NAME=DG5FGrasp.x86_64

# Grasp-ready Reach Linux player
DG5F_REACH_BUILD_OUTPUT=training/builds/DG5FGraspReadyReach
DG5F_REACH_PLAYER_NAME=DG5FGraspReadyReach.x86_64
